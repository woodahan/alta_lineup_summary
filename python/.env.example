# Used by: uv run alta-ratings run --io-backend google
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json
GOOGLE_SHEET_ID=your_google_sheet_id
# Used by: uv run alta-ratings run --io-backend local
LOCAL_WORKBOOK_PATH=/absolute/path/to/players.xlsx

T2_USERNAME=your_username
T2_PASSWORD=your_password
T2_LOGIN_URL=https://www.t2tennis.com/Login.aspx
T2_SEARCH_URL=https://www.t2tennis.com/Player/PlayerHistory.aspx

ULTIMATE_USERNAME=your_username
ULTIMATE_PASSWORD=your_password
ULTIMATE_LOGIN_URL=https://players.ultimatetennis.com/players/sign_in
ULTIMATE_SEARCH_URL=https://players.ultimatetennis.com/players/member_search

# Optional auth, but include search URL to query USTA in each run.
USTA_USERNAME=
USTA_PASSWORD=
USTA_LOGIN_URL=
USTA_SEARCH_URL=https://example.com/usta/search
