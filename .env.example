GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json
GOOGLE_SHEET_ID=your_google_sheet_id

T2_USERNAME=your_username
T2_PASSWORD=your_password
T2_LOGIN_URL=https://example.com/t2/login
T2_SEARCH_URL=https://example.com/t2/search

# Optional; defaults to false (T2-only mode)
ENABLE_ULTIMATE=false

ULTIMATE_USERNAME=your_username
ULTIMATE_PASSWORD=your_password
ULTIMATE_LOGIN_URL=https://example.com/ultimate/login
ULTIMATE_SEARCH_URL=https://example.com/ultimate/search

# Optional source
USTA_USERNAME=
USTA_PASSWORD=
USTA_LOGIN_URL=
USTA_SEARCH_URL=
